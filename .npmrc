onlyBuiltDependencies[]=esbuild

# mermaid 11 的间接依赖(dayjs / sanitize-url / cytoscape / debug)需要被
# vitepress-plugin-mermaid 通过 Vite 的 optimizeDeps 直接 resolve。pnpm 默认
# 把它们藏在 .pnpm/ 里 Vite 看不到,这里 hoist 出来。
public-hoist-pattern[]=*dayjs*
public-hoist-pattern[]=*sanitize-url*
public-hoist-pattern[]=*cytoscape*
public-hoist-pattern[]=*debug*
